<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Restore the same shared NuGet packages used by the rest of the repo into
       the repo-root Packages folder, matching the <ImportGroup> paths in the
       vcxproj (..\..\..\..\Packages from this project's src directory). -->
  <config>
    <add key="repositoryPath" value="..\..\..\..\Packages" />
  </config>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
